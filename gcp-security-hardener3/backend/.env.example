# Bootstrap Service Account Credentials (REQUIRED)
# This service account is used to create temporary service accounts for operations
# Download service account JSON from Google Cloud Console
# See BOOTSTRAP_SERVICE_ACCOUNT.md for detailed instructions
# The bootstrap service account needs these roles:
#   - roles/iam.serviceAccountAdmin
#   - roles/iam.serviceAccountKeyAdmin
#   - roles/resourcemanager.projectIamAdmin
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/bootstrap-service-account.json

# Firebase Configuration (REQUIRED for Firebase token verification)
# Get this from Firebase Console -> Project Settings -> General
# This should match the Firebase project ID used in frontend/.env.local
FIREBASE_PROJECT_ID=your_firebase_project_id

# GCP Project Configuration
# Replace with your actual GCP Project ID
# Note: This might be the same as FIREBASE_PROJECT_ID if Firebase and GCP use the same project
GCP_PROJECT_ID=your_gcp_project_id
GCP_REGION=us-central1

# Backend Configuration
BACKEND_PORT=8000
ENVIRONMENT=development

# Security Settings
ALLOWED_ORIGINS=http://localhost:3000,https://your-firebase-domain.web.app

# Sales Team Notification (for FinOps triggers)
SALES_TEAM_WEBHOOK_URL=https://your-sales-webhook-url

# Gemini AI Configuration (Optional - for AI assistant features)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

